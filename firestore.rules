rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{projectId} {
      // Permite que cualquiera lea los proyectos (Módulo de exploración)
      allow read: if true;
      // Solo permite escribir si el usuario está autenticado (Módulo de publicación)
      allow write: if request.auth != null;
    }
  }
}