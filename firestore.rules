rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper para obtener el rol del usuario
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.authorId || 
        getRole() == 'teacher'
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /whitelist_teachers/{email} {
      allow read: if request.auth != null;
      allow write: if false; // Solo manual o via Admin SDK
    }

    match /whitelist_companies/{domain} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /opportunities/{oppId} {
      allow read: if true;
      allow create, update: if request.auth != null && getRole() == 'company';
      allow delete: if request.auth != null && (getRole() == 'company' && request.auth.uid == resource.data.companyId);
    }
  }
}